VITE_COUNTER_CONTRACT_ADDRESS=

# Anthropic API key (used when LLM_BASE_URL is not set)
ANTHROPIC_API_KEY=

# Local mlx_lm server — takes priority when set
# Start with: mlx_lm.server --model mlx-community/Qwen3.6-35B-A3B-4bit --port 8080
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=mlx-community/Qwen3.6-35B-A3B-4bit
LLM_API_KEY=local
# Qwen3 emits <think>…</think> reasoning blocks by default — set to false to strip them
LLM_ENABLE_THINKING=true
