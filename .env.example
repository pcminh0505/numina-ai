# SimpleCounter contract address on Celo Sepolia
# Deploy contracts/SimpleCounter.sol then paste the address here
# Example: VITE_COUNTER_CONTRACT_ADDRESS=0xYourDeployedContractAddress
VITE_COUNTER_CONTRACT_ADDRESS=

# ── LLM backend (choose one) ──────────────────────────────────────────────────

# Option A: Anthropic API (default)
ANTHROPIC_API_KEY=

# Option B: OpenRouter (free Llama 3.3 70B + paid Claude 3.5 Sonnet for advanced tier)
OPENROUTER_API_KEY=
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_MODEL_PAID=anthropic/claude-3.5-sonnet

# Option C: Local mlx_lm server (or any OpenAI-compatible endpoint)
# Start mlx_lm with: mlx_lm.server --model <model-path> --port 8080
# When LLM_BASE_URL is set it takes priority over OpenRouter and Anthropic.
LLM_BASE_URL=http://localhost:8080/v1
LLM_API_KEY=local
# Set to false to strip <think>…</think> blocks (Qwen3 reasoning tokens)
LLM_ENABLE_THINKING=false

# ── x402 micropayments ────────────────────────────────────────────────────────
# Wallet that receives USDC payments for advanced unlock and chat credits
VITE_X402_TREASURY_ADDRESS=
X402_TREASURY_ADDRESS=
# Advanced reading unlock price in USDC 6-decimal units (default: 500000 = $0.50)
X402_ADVANCED_PRICE=500000
# Chat credits pack price in USDC 6-decimal units (default: 200000 = $0.20)
X402_CREDITS_PRICE=200000

# ── Proof of Ship ─────────────────────────────────────────────────────────────
# Self.xyz Agent ID — register at https://app.ai.self.xyz
SELF_AGENT_ID=

# ── ERC-8004 registration script (pnpm register:agent) ───────────────────────
# Deployer wallet private key (never commit this file with a real key!)
REGISTER_PRIVATE_KEY=
# Hosted URL to your agent metadata JSON
AGENT_URI=
# "mainnet" or "testnet" (default: testnet)
REGISTER_CHAIN=testnet
