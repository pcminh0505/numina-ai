# SimpleCounter contract address on Celo Sepolia
# Deploy contracts/SimpleCounter.sol then paste the address here
# Example: VITE_COUNTER_CONTRACT_ADDRESS=0xYourDeployedContractAddress
VITE_COUNTER_CONTRACT_ADDRESS=

# ── LLM backend (choose one) ──────────────────────────────────────────────────

# Option A: Anthropic API (default)
ANTHROPIC_API_KEY=

# Option B: Local mlx_lm server (or any OpenAI-compatible endpoint)
# Start mlx_lm with: mlx_lm.server --model <model-path> --port 8080
# When LLM_BASE_URL is set it takes priority over ANTHROPIC_API_KEY.
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=
LLM_API_KEY=local
# Set to false to strip <think>…</think> blocks (Qwen3 reasoning tokens)
LLM_ENABLE_THINKING=false
